{
  "manifest_version": 3,
  "name": "Recon",
  "version": "1.0.0",
  "description": "High-signal intelligence. A random headline every new tab.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [],
  "host_permissions": [
    "http://localhost:9645/*"
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
